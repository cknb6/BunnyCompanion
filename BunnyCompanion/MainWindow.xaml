<Window x:Class="BunnyCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小申陪伴"
        Width="320" Height="450"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        SnapsToDevicePixels="True" UseLayoutRounding="True"
        Opacity="0"
        Loaded="Window_Loaded" Closing="Window_Closing"
        MouseRightButtonUp="Window_MouseRightButtonUp">
  <!-- 启动动画：整体缩放 + 上浮，锚点在角色脚底附近 -->
  <Grid x:Name="PetRoot"
        Background="Transparent"
        RenderTransformOrigin="0.5,0.90">
    <Grid.RenderTransform>
      <TransformGroup>
        <ScaleTransform x:Name="IntroScale" ScaleX="0.68" ScaleY="0.68" />
        <TranslateTransform x:Name="IntroOffset" Y="42" />
      </TransformGroup>
    </Grid.RenderTransform>

    <Grid.RowDefinitions>
      <RowDefinition Height="118" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- 对话气泡 -->
    <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Bottom"
          IsHitTestVisible="False" Margin="0,0,0,2">
      <StackPanel x:Name="SpeechHost"
                  Opacity="0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Bottom">
        <Border x:Name="SpeechBubble"
                MaxWidth="286" MinWidth="96"
                Padding="16,11,16,10"
                Margin="6,0,6,0"
                CornerRadius="20"
                BorderBrush="#F4C2D4"
                BorderThickness="1.2"
                Visibility="Collapsed">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#FFFFFEFF" Offset="0" />
              <GradientStop Color="#FFFFF5F9" Offset="0.55" />
              <GradientStop Color="#FFFFEAF2" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Direction="270"
                              Opacity="0.22" Color="#B86A86" />
          </Border.Effect>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="♡" FontSize="13" Foreground="#E978A0"
                       VerticalAlignment="Top" Margin="0,1,7,0" Opacity="0.92" />
            <TextBlock x:Name="SpeechText"
                       Grid.Column="1"
                       FontFamily="{StaticResource AppFont}"
                       FontSize="13.2"
                       LineHeight="20"
                       Foreground="#5A3A48"
                       TextAlignment="Left"
                       TextWrapping="Wrap" />
          </Grid>
        </Border>
        <Path x:Name="SpeechTail"
              Visibility="Collapsed"
              HorizontalAlignment="Center"
              Margin="0,-1,0,0"
              Data="M 0,0 L 14,0 L 7,9 Z"
              Stroke="#F4C2D4"
              StrokeThickness="1">
          <Path.Fill>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#FFFFF5F9" Offset="0" />
              <GradientStop Color="#FFFFEAF2" Offset="1" />
            </LinearGradientBrush>
          </Path.Fill>
        </Path>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1" x:Name="CharacterHost">
      <Border x:Name="FocusBadge"
              Visibility="Collapsed" IsHitTestVisible="False"
              HorizontalAlignment="Center" VerticalAlignment="Top"
              Margin="0,2,0,0" Padding="12,5"
              CornerRadius="13"
              BorderBrush="#FFD4E1" BorderThickness="1"
              Panel.ZIndex="2">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F2FFF8FB" Offset="0" />
            <GradientStop Color="#E8FFEAF2" Offset="1" />
          </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
          <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#8D5068" />
        </Border.Effect>
        <TextBlock x:Name="FocusText" FontFamily="{StaticResource AppFont}"
                   FontSize="12" FontWeight="SemiBold" Foreground="#B44F74" />
      </Border>

      <Image x:Name="PetImage"
             Margin="2,0,2,2"
             Stretch="Uniform" StretchDirection="Both"
             RenderOptions.BitmapScalingMode="HighQuality"
             RenderTransformOrigin="0.5,0.82"
             Cursor="Hand"
             MouseLeftButtonDown="PetImage_MouseLeftButtonDown"
             MouseLeftButtonUp="PetImage_MouseLeftButtonUp"
             MouseMove="PetImage_MouseMove"
             MouseDown="PetImage_MouseDown"
             LostMouseCapture="PetImage_LostMouseCapture">
        <Image.RenderTransform>
          <TransformGroup>
            <ScaleTransform x:Name="FacingTransform" ScaleX="1" ScaleY="1" />
            <RotateTransform x:Name="TiltTransform" Angle="0" />
            <TranslateTransform x:Name="MotionTransform" X="0" Y="0" />
          </TransformGroup>
        </Image.RenderTransform>
      </Image>
    </Grid>
  </Grid>
</Window>

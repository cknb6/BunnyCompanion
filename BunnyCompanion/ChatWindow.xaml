<Window x:Class="BunnyCompanion.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小申"
        Width="420" Height="680"
        MinWidth="320" MinHeight="420"
        WindowStartupLocation="Manual"
        Background="#EDEDED"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="True"
        Topmost="False"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        AllowDrop="True"
        PreviewDragEnter="Window_PreviewDragEnter"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDragLeave="Window_PreviewDragLeave"
        PreviewDrop="Window_PreviewDrop"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
  <Window.Resources>
    <!-- 微信绿发送按钮 -->
    <Style x:Key="WxSendButton" TargetType="Button">
      <Setter Property="Background" Value="#07C160" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#06AD56" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="#A0DDB8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 底部工具图标按钮 -->
    <Style x:Key="WxIconButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="36" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="Foreground" Value="#191919" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                    Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#E5E5E5" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 快捷芯片（轻量） -->
    <Style x:Key="WxChip" TargetType="Button">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#576B95" />
      <Setter Property="BorderBrush" Value="#E5E5E5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="14" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border BorderBrush="#D9D9D9" BorderThickness="1" Background="#EDEDED">
    <Grid>
      <Grid.RowDefinitions>
        <!-- 顶栏 -->
        <RowDefinition Height="Auto" />
        <!-- 消息区 -->
        <RowDefinition Height="*" />
        <!-- 快捷回复 -->
        <RowDefinition Height="Auto" />
        <!-- 附件条 -->
        <RowDefinition Height="Auto" />
        <!-- 输入区（微信风格） -->
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- 拖入文件时的全窗提示层（盖在内容上，不拦截布局） -->
      <Border x:Name="DropOverlay" Grid.Row="0" Grid.RowSpan="5"
              Background="#CC07C160" Visibility="Collapsed" IsHitTestVisible="False"
              Panel.ZIndex="100">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Text="松开即可添加附件" FontSize="20" FontWeight="SemiBold"
                     Foreground="White" HorizontalAlignment="Center" />
          <TextBlock Text="图片 / 文本 / 代码 / 任意文件路径 · 最多 6 个 · 单文件 ≤8MB"
                     FontSize="13" Foreground="#F0FFF6" HorizontalAlignment="Center" Margin="0,8,0,0" />
        </StackPanel>
      </Border>

      <!-- ========== 顶栏：拖动 + 标题 ========== -->
      <Border Grid.Row="0" Background="#EDEDED" BorderBrush="#D9D9D9" BorderThickness="0,0,0,1"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid Height="48" Margin="8,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Button x:Name="CloseButton" Content="‹" FontSize="22" Style="{StaticResource WxIconButton}"
                  Click="CloseButton_Click" ToolTip="关闭" VerticalAlignment="Center" />

          <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="TitleText" Text="小申" FontSize="16" FontWeight="SemiBold"
                       Foreground="#191919" HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText" Text="在线" FontSize="11" Foreground="#B2B2B2"
                       HorizontalAlignment="Center" Margin="0,1,0,0" />
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="🗑" Style="{StaticResource WxIconButton}" ToolTip="清空对话"
                    Click="ClearButton_Click" FontSize="14" />
            <Button Content="—" Style="{StaticResource WxIconButton}" ToolTip="最小化"
                    Click="MinimizeButton_Click" FontSize="16" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- ========== 消息列表 ========== -->
      <Border Grid.Row="1" Background="#EDEDED">
        <ScrollViewer x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,8,0,4">
          <StackPanel x:Name="ChatPanel" Margin="10,0,10,8" />
        </ScrollViewer>
      </Border>

      <!-- ========== 快捷芯片 ========== -->
      <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                    Background="#EDEDED" Padding="10,0,10,6">
        <StackPanel Orientation="Horizontal">
          <Button Content="看桌面" Style="{StaticResource WxChip}" Click="LookDesktop_Click" />
          <Button Content="天气预警" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="帮我查当前位置天气，重点说高温和降水预警" />
          <Button Content="我在哪" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="我现在在哪？顺便告诉我外面天气怎样" />
          <Button Content="星座运势" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="按我的生日或星座做个趣味星座分析，再给今日运势" />
          <Button Content="设个提醒" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="提醒我30分钟后起来喝水活动一下" />
          <Button Content="今日卡片" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="给我一张今日陪伴卡，穿搭和习惯都来点" />
          <Button Content="列桌面文件" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="列出我桌面上的文件和文件夹" />
          <Button Content="想你了" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="想你了" />
          <Button Content="好累呀" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="好累呀" />
        </StackPanel>
      </ScrollViewer>

      <!-- ========== 待发送附件预览 ========== -->
      <Border x:Name="AttachBar" Grid.Row="3" Background="#F7F7F7" BorderBrush="#E5E5E5"
              BorderThickness="0,1,0,0" Visibility="Collapsed" Padding="10,8">
        <DockPanel>
          <Button DockPanel.Dock="Right" Content="清除" Style="{StaticResource WxChip}"
                  Margin="8,0,0,0" Click="ClearAttachments_Click" />
          <StackPanel>
            <TextBlock Text="待发送附件" FontSize="11" Foreground="#888" Margin="0,0,0,4" />
            <WrapPanel x:Name="AttachPreviewPanel" />
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ========== 输入区（仿微信） ========== -->
      <Border Grid.Row="4" Background="#F7F7F7" BorderBrush="#D9D9D9" BorderThickness="0,1,0,0">
        <Grid Margin="8,8,8,10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- 工具行：+ 附件 / 语音 / 看桌面勾选 -->
          <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <Button x:Name="AttachButton" DockPanel.Dock="Left" Content="＋" FontSize="20"
                    Style="{StaticResource WxIconButton}"
                    ToolTip="上传图片 / 文件（也可拖入窗口，或 Ctrl+V 粘贴）"
                    AutomationProperties.Name="添加附件"
                    Click="AttachButton_Click" />
            <Button x:Name="VoiceButton" DockPanel.Dock="Left" Content="🎤" FontSize="16"
                    Style="{StaticResource WxIconButton}" ToolTip="语音输入（需 Windows 语音识别）"
                    AutomationProperties.Name="语音输入"
                    Click="VoiceButton_Click" Margin="2,0,0,0" />
            <CheckBox x:Name="DesktopCheck" Content="附带桌面截图" IsChecked="False"
                      Foreground="#576B95" FontSize="12" VerticalAlignment="Center"
                      Margin="6,0,0,0" />
            <TextBlock DockPanel.Dock="Right" Text="拖文件 / Ctrl+V · Enter 发送"
                       FontSize="11" Foreground="#B2B2B2" VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
          </DockPanel>

          <!-- 输入框 -->
          <Border Grid.Row="1" Background="White" CornerRadius="4" BorderBrush="#E5E5E5"
                  BorderThickness="1" Padding="2">
            <TextBox x:Name="InputBox"
                     MaxLength="4000"
                     MinHeight="56"
                     MaxHeight="140"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="8,8"
                     FontSize="14"
                     Foreground="#191919"
                     CaretBrush="#07C160"
                     AllowDrop="False"
                     PreviewKeyDown="InputBox_PreviewKeyDown" />
          </Border>

          <!-- 发送 -->
          <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <Button x:Name="SendButton" DockPanel.Dock="Right" Content="发送"
                    Style="{StaticResource WxSendButton}"
                    MinWidth="72" Height="34"
                    Click="SendButton_Click" />
            <TextBlock x:Name="TypingHint" Text="" FontSize="11" Foreground="#B2B2B2"
                       VerticalAlignment="Center" />
          </DockPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>

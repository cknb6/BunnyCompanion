<Window x:Class="BunnyCompanion.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小申"
        Width="420" Height="680"
        MinWidth="320" MinHeight="420"
        WindowStartupLocation="Manual"
        Background="#F3F5F8"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="True"
        Topmost="False"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        AllowDrop="True"
        PreviewDragEnter="Window_PreviewDragEnter"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDragLeave="Window_PreviewDragLeave"
        PreviewDrop="Window_PreviewDrop"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
  <Window.Resources>
    <!-- ============ 全局美化：细圆角滚动条（垂直/水平两态） ============ -->
    <Style x:Key="SoftScrollThumb" TargetType="Thumb">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="Bd" Background="#C9CFD9" CornerRadius="4" Margin="1"
                    SnapsToDevicePixels="True" />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#A7B0BE" />
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#8F99AB" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ScrollBar">
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Background" Value="Transparent" />
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Vertical">
          <Setter Property="Width" Value="8" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid Background="Transparent">
                  <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                      <Thumb Style="{StaticResource SoftScrollThumb}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                    </Track.IncreaseRepeatButton>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Height" Value="8" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid Background="Transparent">
                  <Track x:Name="PART_Track" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                      <Thumb Style="{StaticResource SoftScrollThumb}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False" />
                    </Track.IncreaseRepeatButton>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- ============ 微信绿发送按钮（大圆角 + 悬停/按下/禁用三态） ============ -->
    <Style x:Key="WxSendButton" TargetType="Button">
      <Setter Property="Background" Value="#07C160" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="8" Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270"
                                  Opacity="0.20" Color="#3E4550" />
              </Border.Effect>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <!-- 悬停/按下用透明度变化：发送(绿)与停止(红)两种底色都适配 -->
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.86" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.72" />
                <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.55" />
                <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ============ 工具图标按钮（圆形悬停光晕） ============ -->
    <Style x:Key="WxIconButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="36" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="Foreground" Value="#3E4550" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="18"
                    Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#14000000" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#24000000" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ============ 快捷芯片（药丸形 + 轻阴影 + 悬停淡绿） ============ -->
    <Style x:Key="WxChip" TargetType="Button">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#576B95" />
      <Setter Property="BorderBrush" Value="#E3E8EF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16" Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Direction="270"
                                  Opacity="0.08" Color="#42506B" />
              </Border.Effect>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#F0FBF4" />
                <Setter TargetName="Bd" Property="BorderBrush" Value="#B9E7CC" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#E2F6E9" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ============ 圆角勾选框（微信绿对勾） ============ -->
    <Style x:Key="WxCheck" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#576B95" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal">
              <Border x:Name="Box" Width="16" Height="16" CornerRadius="5"
                      BorderBrush="#C3CAD6" BorderThickness="1.5" Background="White"
                      SnapsToDevicePixels="True">
                <Path x:Name="Tick" Data="M 3.2,8.4 L 6.8,11.8 L 12.8,4.6" Stroke="White"
                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Visibility="Collapsed" Stretch="None"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box" Property="Background" Value="#07C160" />
                <Setter TargetName="Box" Property="BorderBrush" Value="#07C160" />
                <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="#07C160" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border BorderBrush="#D8DEE6" BorderThickness="1" Background="#F3F5F8">
    <Grid>
      <Grid.RowDefinitions>
        <!-- 顶栏 -->
        <RowDefinition Height="Auto" />
        <!-- 消息区 -->
        <RowDefinition Height="*" />
        <!-- 快捷回复 -->
        <RowDefinition Height="Auto" />
        <!-- 附件条 -->
        <RowDefinition Height="Auto" />
        <!-- 输入区（微信风格） -->
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- 拖入文件时的全窗提示层（盖在内容上，不拦截布局） -->
      <Border x:Name="DropOverlay" Grid.Row="0" Grid.RowSpan="5"
              Background="#E807C160" Visibility="Collapsed" IsHitTestVisible="False"
              Panel.ZIndex="100">
        <Border Background="#F2FFFFFF" CornerRadius="18" Padding="34,26"
                BorderBrush="White" BorderThickness="2"
                VerticalAlignment="Center" HorizontalAlignment="Center">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="📎" FontSize="30" HorizontalAlignment="Center" />
            <TextBlock Text="松开即可添加附件" FontSize="19" FontWeight="SemiBold"
                       Foreground="#078A48" HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Text="支持资源管理器 / 微信拖图 · 最多 6 个 · 单文件 ≤8MB"
                       FontSize="12.5" Foreground="#3E9C69" HorizontalAlignment="Center" Margin="0,7,0,0" />
          </StackPanel>
        </Border>
      </Border>

      <!-- ========== 顶栏：白色 + 拖动 + 标题 ========== -->
      <Border Grid.Row="0" Background="White" BorderBrush="#E6E9EF" BorderThickness="0,0,0,1"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Border.Effect>
          <DropShadowEffect BlurRadius="6" ShadowDepth="1" Direction="270"
                            Opacity="0.05" Color="#1B2430" />
        </Border.Effect>
        <Grid Height="50" Margin="8,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Button x:Name="CloseButton" Content="‹" FontSize="22" Style="{StaticResource WxIconButton}"
                  Click="CloseButton_Click" ToolTip="关闭" VerticalAlignment="Center" />

          <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="TitleText" Text="小申" FontSize="16" FontWeight="SemiBold"
                       Foreground="#1A1A1A" HorizontalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
              <!-- 在线状态小绿点，配合状态文字 -->
              <Ellipse Width="6" Height="6" Fill="#07C160" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBlock x:Name="StatusText" Text="在线" FontSize="11" Foreground="#98A1AD" />
            </StackPanel>
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <!-- 陪伴 / 办公 Agent 模式切换（参考 Claude Code 多步工具） -->
            <Button x:Name="ModeToggleButton" Content="💬" Style="{StaticResource WxIconButton}"
                    ToolTip="当前：陪伴模式。点击切换到办公 Agent"
                    Click="ModeToggleButton_Click" FontSize="14"
                    AutomationProperties.Name="切换陪伴或办公模式" />
            <!-- 右上角：随时开/关朗读；关时立即停止当前播放 -->
            <Button x:Name="SoundToggleButton" Content="🔊" Style="{StaticResource WxIconButton}"
                    ToolTip="声音开：点击关闭朗读"
                    Click="SoundToggleButton_Click" FontSize="15"
                    AutomationProperties.Name="切换朗读声音" />
            <Button Content="🗑" Style="{StaticResource WxIconButton}" ToolTip="清空对话"
                    Click="ClearButton_Click" FontSize="14" />
            <Button Content="—" Style="{StaticResource WxIconButton}" ToolTip="最小化"
                    Click="MinimizeButton_Click" FontSize="16" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- ========== 消息列表：柔光渐变底 ========== -->
      <Border Grid.Row="1">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FAFBFD" Offset="0" />
            <GradientStop Color="#F2F4F8" Offset="1" />
          </LinearGradientBrush>
        </Border.Background>
        <ScrollViewer x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,10,0,4">
          <StackPanel x:Name="ChatPanel" Margin="12,0,12,10" />
        </ScrollViewer>
      </Border>

      <!-- ========== 快捷芯片 ========== -->
      <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                    Background="#F3F5F8" Padding="12,2,12,8">
        <StackPanel Orientation="Horizontal">
          <Button Content="看桌面" Style="{StaticResource WxChip}" Click="LookDesktop_Click" />
          <Button Content="天气预警" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="帮我查当前位置天气，重点说高温和降水预警" />
          <Button Content="我在哪" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="我现在在哪？顺便告诉我外面天气怎样" />
          <Button Content="星座运势" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="按我的生日或星座做个趣味星座分析，再给今日运势" />
          <Button Content="设个提醒" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="提醒我30分钟后起来喝水活动一下" />
          <Button Content="今日卡片" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="给我一张今日陪伴卡，穿搭和习惯都来点" />
          <Button Content="列桌面文件" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="列出我桌面上的文件和文件夹" />
          <Button Content="整理桌面PDF" Style="{StaticResource WxChip}" Click="QuickChip_Click"
                  Tag="【办公任务】先 plan_set 再批量搜索桌面 *.pdf，用 batch_move dry_run 预览整理到「文档\\PDF」，列出清单等我确认" />
          <Button Content="搜网页摘要" Style="{StaticResource WxChip}" Click="QuickChip_Click"
                  Tag="用 web_search_results 搜索：Windows 11 清理磁盘空间技巧，总结 3 条可执行建议" />
          <Button Content="写个备忘文件" Style="{StaticResource WxChip}" Click="QuickChip_Click"
                  Tag="在文档目录写一个 today-notes.txt，内容是今日待办三条，写完告诉我完整路径" />
          <Button Content="想你了" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="想你了" />
          <Button Content="好累呀" Style="{StaticResource WxChip}" Click="QuickChip_Click" Tag="好累呀" />
        </StackPanel>
      </ScrollViewer>

      <!-- ========== 待发送附件预览 ========== -->
      <Border x:Name="AttachBar" Grid.Row="3" Background="White" BorderBrush="#E6E9EF"
              BorderThickness="0,1,0,0" Visibility="Collapsed" Padding="12,9">
        <DockPanel>
          <Button DockPanel.Dock="Right" Content="清除" Style="{StaticResource WxChip}"
                  Margin="8,0,0,0" Click="ClearAttachments_Click" />
          <StackPanel>
            <TextBlock Text="待发送附件" FontSize="11" Foreground="#98A1AD" Margin="0,0,0,4" />
            <WrapPanel x:Name="AttachPreviewPanel" />
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ========== 输入区（仿微信 · 白底） ========== -->
      <Border Grid.Row="4" Background="White" BorderBrush="#E6E9EF" BorderThickness="0,1,0,0">
        <Grid Margin="10,9,10,12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- 工具行：+ 附件 / 语音 / 看桌面勾选 -->
          <DockPanel Grid.Row="0" Margin="0,0,0,7">
            <Button x:Name="AttachButton" DockPanel.Dock="Left" Content="＋" FontSize="20"
                    Style="{StaticResource WxIconButton}"
                    ToolTip="上传图片 / 文件（也可拖入窗口，或 Ctrl+V 粘贴）"
                    AutomationProperties.Name="添加附件"
                    Click="AttachButton_Click" />
            <Button x:Name="VoiceButton" DockPanel.Dock="Left" Content="🎤" FontSize="16"
                    Style="{StaticResource WxIconButton}" ToolTip="语音输入（需 Windows 语音识别）"
                    AutomationProperties.Name="语音输入"
                    Click="VoiceButton_Click" Margin="2,0,0,0" />
            <CheckBox x:Name="DesktopCheck" Content="附带桌面截图" IsChecked="False"
                      Style="{StaticResource WxCheck}"
                      Margin="8,0,0,0" />
            <TextBlock DockPanel.Dock="Right" Text="拖文件 / Ctrl+V · Enter 发送"
                       FontSize="11" Foreground="#B7BEC9" VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
          </DockPanel>

          <!-- 输入框：圆角白卡，聚焦时描边变绿 -->
          <Border Grid.Row="1" Background="#F7F8FA" CornerRadius="10"
                  BorderThickness="1.5" Padding="2"
                  SnapsToDevicePixels="True">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#E4E8EF" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=InputBox}" Value="True">
                    <Setter Property="BorderBrush" Value="#07C160" />
                    <Setter Property="Background" Value="White" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBox x:Name="InputBox"
                     MaxLength="4000"
                     MinHeight="56"
                     MaxHeight="140"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="10,9"
                     FontSize="14"
                     Foreground="#1A1A1A"
                     CaretBrush="#07C160"
                     SelectionBrush="#B9E7CC"
                     AllowDrop="False"
                     PreviewKeyDown="InputBox_PreviewKeyDown" />
          </Border>

          <!-- 发送 -->
          <DockPanel Grid.Row="2" Margin="0,9,0,0">
            <Button x:Name="SendButton" DockPanel.Dock="Right" Content="发送"
                    Style="{StaticResource WxSendButton}"
                    MinWidth="76" Height="34"
                    Click="SendButton_Click" />
            <TextBlock x:Name="TypingHint" Text="" FontSize="11" Foreground="#98A1AD"
                       VerticalAlignment="Center" />
          </DockPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>

<Window x:Class="BunnyCompanion.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小申陪伴 · 个性化设置"
        Width="590" Height="760" MinWidth="500" MinHeight="420"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded"
        Background="#FFF9FB" FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="True">
  <Window.Resources>
    <!-- ============ 滚动条：细圆角半透明（垂直/水平两态） ============ -->
    <Style x:Key="SoftScrollThumb" TargetType="Thumb">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="Bd" Background="#E5C4D2" CornerRadius="4" Margin="1"
                    SnapsToDevicePixels="True" />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#D9A3B9" />
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#C98AA6" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ScrollBar">
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Background" Value="Transparent" />
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Vertical">
          <Setter Property="Width" Value="8" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid Background="Transparent">
                  <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                      <Thumb Style="{StaticResource SoftScrollThumb}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                    </Track.IncreaseRepeatButton>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Height" Value="8" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid Background="Transparent">
                  <Track x:Name="PART_Track" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                      <Thumb Style="{StaticResource SoftScrollThumb}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False" />
                    </Track.IncreaseRepeatButton>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- ============ 基础文字 / 输入框（圆角 + 聚焦粉色描边） ============ -->
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#513A45" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="0,5,0,0" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#513A45" />
      <Setter Property="CaretBrush" Value="#E978A0" />
      <Setter Property="SelectionBrush" Value="#F6CBDC" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="Bd" Background="White" CornerRadius="9"
                    BorderBrush="#F0D7E0" BorderThickness="1.5"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost" Margin="0"
                            VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="#E978A0" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="#E9B4CA" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="#FAF4F7" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="DatePicker">
      <Setter Property="Margin" Value="0,5,0,0" />
      <Setter Property="BorderBrush" Value="#F0D7E0" />
    </Style>

    <!-- ============ 勾选框：圆角粉底对勾 ============ -->
    <Style TargetType="CheckBox">
      <Setter Property="Margin" Value="0,5,18,7" />
      <Setter Property="Foreground" Value="#513A45" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal">
              <Border x:Name="Box" Width="17" Height="17" CornerRadius="5"
                      BorderBrush="#E0B9CA" BorderThickness="1.5" Background="White"
                      SnapsToDevicePixels="True">
                <Path x:Name="Tick" Data="M 3.4,8.6 L 7,12 L 13.2,4.8" Stroke="White"
                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Visibility="Collapsed" Stretch="None"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box" Property="Background" Value="#E978A0" />
                <Setter TargetName="Box" Property="BorderBrush" Value="#E978A0" />
                <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="#E978A0" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ============ 滑块：粉色圆头 + 浅粉轨道 ============ -->
    <Style x:Key="PinkSliderThumb" TargetType="Thumb">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Ellipse x:Name="Dot" Width="18" Height="18" Fill="#E978A0"
                     Stroke="White" StrokeThickness="2.5"
                     SnapsToDevicePixels="True">
              <Ellipse.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Direction="270"
                                  Opacity="0.25" Color="#B65076" />
              </Ellipse.Effect>
            </Ellipse>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Dot" Property="Fill" Value="#F08FB2" />
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="Dot" Property="Fill" Value="#D45E8C" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="Slider">
      <Setter Property="Height" Value="22" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid>
              <Border Height="5" CornerRadius="2.5" Background="#F4E1E8"
                      VerticalAlignment="Center" />
              <Track x:Name="PART_Track">
                <Track.Thumb>
                  <Thumb Style="{StaticResource PinkSliderThumb}" />
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ============ 分区卡片 ============ -->
    <Style x:Key="SectionStyle" TargetType="Border">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#F4E1E8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="0,0,0,14" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270"
                            Opacity="0.06" Color="#B65076" />
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ============ 按钮：主（粉）/ 次（白描边） ============ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#E978A0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="24,10" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10"
                    Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
              <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270"
                                  Opacity="0.22" Color="#E978A0" />
              </Border.Effect>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#F08FB2" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#D45E8C" />
                <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="#F3C9D9" />
                <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="SecondaryButton" TargetType="Button">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#765462" />
      <Setter Property="BorderBrush" Value="#EBCDD9" />
      <Setter Property="Padding" Value="20,9" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10"
                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.5"
                    Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#FDF2F7" />
                <Setter TargetName="Bd" Property="BorderBrush" Value="#E978A0" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#FBE4EE" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="26,22,26,15">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="♡" FontSize="22" FontWeight="Bold" Foreground="#E978A0"
                   VerticalAlignment="Center" Margin="0,0,8,2" />
        <TextBlock Text="小申陪伴" FontSize="25" FontWeight="SemiBold" Foreground="#B65076"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock Text="名字、提醒和纪念日均只保存在本机。" Margin="1,5,0,0" Foreground="#8B7480" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,0,18,0">
      <StackPanel Margin="0,0,8,10">
        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="称呼与外观" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="桌宠名字" />
                <TextBox x:Name="PetNameBox" MaxLength="20" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="她希望被怎样称呼" />
                <TextBox x:Name="PartnerNameBox" MaxLength="20" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,15,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="56" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="角色大小" VerticalAlignment="Center" Margin="0,0,12,0" />
              <Slider x:Name="ScaleSlider" Grid.Column="1" Minimum="0.65" Maximum="1.5"
                      TickFrequency="0.05" IsSnapToTickEnabled="True"
                      ValueChanged="ScaleSlider_ValueChanged" />
              <TextBlock x:Name="ScaleValueText" Grid.Column="2" TextAlignment="Right"
                         VerticalAlignment="Center" Foreground="#A84C6E" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="语音与系统关怀" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <WrapPanel Margin="0,9,0,0">
              <CheckBox x:Name="TtsCheck" Content="朗读回复" />
              <CheckBox x:Name="VoiceInputCheck" Content="语音输入" />
              <CheckBox x:Name="AutoUpdateCheck" Content="自动检查更新（每5分钟）" />
              <CheckBox x:Name="SystemTriggerCheck" Content="启用系统状态提醒" />
            </WrapPanel>
            <TextBlock Text="开启后每 5 分钟检测 GitHub Release；发现新版本会自动下载、SHA256 校验并覆盖当前 EXE 后重启。仅官方仓库。"
                       FontSize="11.5" Foreground="#917B85" TextWrapping="Wrap" Margin="0,4,0,0" />
            <TextBlock Text="阈值填写 0 可关闭对应提醒；系统状态只在非安静时段提示。"
                       FontSize="11.5" Foreground="#917B85" TextWrapping="Wrap" />
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="CPU 提醒阈值（0–100%）" />
                <TextBox x:Name="CpuThresholdBox" MaxLength="3" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="内存提醒阈值（0–100%）" />
                <TextBox x:Name="MemoryThresholdBox" MaxLength="3" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="低电量提醒阈值（0–100%）" />
                <TextBox x:Name="BatteryThresholdBox" MaxLength="3" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="离开多久算久离（分钟，0 关闭）" />
                <TextBox x:Name="IdleMinutesBox" MaxLength="4" />
              </StackPanel>
            </Grid>
            <StackPanel Margin="0,13,0,0">
              <TextBlock Text="同类提醒冷却（分钟，1–1440）" />
              <TextBox x:Name="TriggerCooldownBox" MaxLength="4" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="运行方式" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <WrapPanel Margin="0,9,0,0">
              <CheckBox x:Name="StartupCheck" Content="开机自动启动" />
              <CheckBox x:Name="AutoWalkCheck" Content="自动散步" />
              <CheckBox x:Name="TopmostCheck" Content="始终置顶" />
              <CheckBox x:Name="SoundCheck" Content="提示音" />
              <CheckBox x:Name="BubbleCheck" Content="显示对话气泡" />
              <CheckBox x:Name="QuietModeCheck" Content="安静模式" />
              <CheckBox x:Name="FullscreenCheck" Content="全屏时自动隐藏" />
              <CheckBox x:Name="ClickThroughCheck" Content="鼠标穿透" />
            </WrapPanel>
            <TextBlock Text="开启鼠标穿透后，需要从系统托盘取消；安静时段仍会自动停止声音和主动提醒。"
                       FontSize="11.5" Foreground="#917B85" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="健康提醒与安静时段" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="喝水提醒（分钟，0 为关闭）" />
                <TextBox x:Name="WaterReminderBox" MaxLength="3" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="休息提醒（分钟，0 为关闭）" />
                <TextBox x:Name="RestReminderBox" MaxLength="3" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="安静开始（HH:mm）" />
                <TextBox x:Name="QuietStartBox" MaxLength="5" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="安静结束（HH:mm）" />
                <TextBox x:Name="QuietEndBox" MaxLength="5" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="重要日期" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="生日（可留空）" />
                <DatePicker x:Name="BirthdayPicker" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="纪念日（可留空）" />
                <DatePicker x:Name="AnniversaryPicker" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="专属对话" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <TextBlock Margin="0,5,0,0" FontSize="11.5" Foreground="#917B85"
                       Text="每行一句；{name} 会替换为上方称呼，{pet} 会替换为桌宠名字。" />
            <TextBox x:Name="MessagesBox" Height="180" Margin="0,10,0,0"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="#FFF9FB" BorderBrush="#F0DDE4" BorderThickness="0,1,0,0">
      <Grid Margin="18,12,26,15">
        <Button Content="恢复推荐设置" Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Left" Click="ResetButton_Click" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="取消" Style="{StaticResource SecondaryButton}" IsCancel="True" />
          <Button Content="保存" Style="{StaticResource PrimaryButton}" IsDefault="True"
                  Click="SaveButton_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>

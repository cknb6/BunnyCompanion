<Window x:Class="BunnyCompanion.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小申陪伴 · 个性化设置"
        Width="590" Height="760" MinWidth="500" MinHeight="420"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded"
        Background="#FFF9FB" FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="True">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#513A45" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="0,5,0,0" />
      <Setter Property="Padding" Value="9,7" />
      <Setter Property="BorderBrush" Value="#F0D7E0" />
      <Setter Property="Background" Value="White" />
    </Style>
    <Style TargetType="DatePicker">
      <Setter Property="Margin" Value="0,5,0,0" />
      <Setter Property="BorderBrush" Value="#F0D7E0" />
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Margin" Value="0,5,18,7" />
      <Setter Property="Foreground" Value="#513A45" />
    </Style>
    <Style x:Key="SectionStyle" TargetType="Border">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#F4E1E8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="Margin" Value="0,0,0,14" />
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#E978A0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="22,9" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style x:Key="SecondaryButton" TargetType="Button">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#765462" />
      <Setter Property="BorderBrush" Value="#EBCDD9" />
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="26,22,26,15">
      <TextBlock Text="小申陪伴" FontSize="25" FontWeight="SemiBold" Foreground="#B65076" />
      <TextBlock Text="名字、提醒和纪念日均只保存在本机。" Margin="1,5,0,0" Foreground="#8B7480" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,0,18,0">
      <StackPanel Margin="0,0,8,10">
        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="称呼与外观" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="桌宠名字" />
                <TextBox x:Name="PetNameBox" MaxLength="20" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="她希望被怎样称呼" />
                <TextBox x:Name="PartnerNameBox" MaxLength="20" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,15,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="56" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="角色大小" VerticalAlignment="Center" Margin="0,0,12,0" />
              <Slider x:Name="ScaleSlider" Grid.Column="1" Minimum="0.65" Maximum="1.5"
                      TickFrequency="0.05" IsSnapToTickEnabled="True"
                      ValueChanged="ScaleSlider_ValueChanged" />
              <TextBlock x:Name="ScaleValueText" Grid.Column="2" TextAlignment="Right"
                         VerticalAlignment="Center" Foreground="#A84C6E" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="语音与系统关怀" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <WrapPanel Margin="0,9,0,0">
              <CheckBox x:Name="TtsCheck" Content="朗读回复" />
              <CheckBox x:Name="VoiceInputCheck" Content="语音输入" />
              <CheckBox x:Name="AutoUpdateCheck" Content="自动检查更新（每5分钟）" />
              <CheckBox x:Name="SystemTriggerCheck" Content="启用系统状态提醒" />
            </WrapPanel>
            <TextBlock Text="开启后每 5 分钟检测 GitHub Release；发现新版本会自动下载、SHA256 校验并覆盖当前 EXE 后重启。仅官方仓库。"
                       FontSize="11.5" Foreground="#917B85" TextWrapping="Wrap" Margin="0,4,0,0" />
            <TextBlock Text="阈值填写 0 可关闭对应提醒；系统状态只在非安静时段提示。"
                       FontSize="11.5" Foreground="#917B85" TextWrapping="Wrap" />
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="CPU 提醒阈值（0–100%）" />
                <TextBox x:Name="CpuThresholdBox" MaxLength="3" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="内存提醒阈值（0–100%）" />
                <TextBox x:Name="MemoryThresholdBox" MaxLength="3" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="低电量提醒阈值（0–100%）" />
                <TextBox x:Name="BatteryThresholdBox" MaxLength="3" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="离开多久算久离（分钟，0 关闭）" />
                <TextBox x:Name="IdleMinutesBox" MaxLength="4" />
              </StackPanel>
            </Grid>
            <StackPanel Margin="0,13,0,0">
              <TextBlock Text="同类提醒冷却（分钟，1–1440）" />
              <TextBox x:Name="TriggerCooldownBox" MaxLength="4" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="运行方式" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <WrapPanel Margin="0,9,0,0">
              <CheckBox x:Name="StartupCheck" Content="开机自动启动" />
              <CheckBox x:Name="AutoWalkCheck" Content="自动散步" />
              <CheckBox x:Name="TopmostCheck" Content="始终置顶" />
              <CheckBox x:Name="SoundCheck" Content="提示音" />
              <CheckBox x:Name="BubbleCheck" Content="显示对话气泡" />
              <CheckBox x:Name="QuietModeCheck" Content="安静模式" />
              <CheckBox x:Name="FullscreenCheck" Content="全屏时自动隐藏" />
              <CheckBox x:Name="ClickThroughCheck" Content="鼠标穿透" />
            </WrapPanel>
            <TextBlock Text="开启鼠标穿透后，需要从系统托盘取消；安静时段仍会自动停止声音和主动提醒。"
                       FontSize="11.5" Foreground="#917B85" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="健康提醒与安静时段" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="喝水提醒（分钟，0 为关闭）" />
                <TextBox x:Name="WaterReminderBox" MaxLength="3" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="休息提醒（分钟，0 为关闭）" />
                <TextBox x:Name="RestReminderBox" MaxLength="3" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="安静开始（HH:mm）" />
                <TextBox x:Name="QuietStartBox" MaxLength="5" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="安静结束（HH:mm）" />
                <TextBox x:Name="QuietEndBox" MaxLength="5" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="重要日期" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <Grid Margin="0,13,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="生日（可留空）" />
                <DatePicker x:Name="BirthdayPicker" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="纪念日（可留空）" />
                <DatePicker x:Name="AnniversaryPicker" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionStyle}">
          <StackPanel>
            <TextBlock Text="专属对话" FontSize="16" FontWeight="SemiBold" Foreground="#A84C6E" />
            <TextBlock Margin="0,5,0,0" FontSize="11.5" Foreground="#917B85"
                       Text="每行一句；{name} 会替换为上方称呼，{pet} 会替换为桌宠名字。" />
            <TextBox x:Name="MessagesBox" Height="180" Margin="0,10,0,0"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="#FFF9FB" BorderBrush="#F0DDE4" BorderThickness="0,1,0,0">
      <Grid Margin="18,12,26,15">
        <Button Content="恢复推荐设置" Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Left" Click="ResetButton_Click" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="取消" Style="{StaticResource SecondaryButton}" IsCancel="True" />
          <Button Content="保存" Style="{StaticResource PrimaryButton}" IsDefault="True"
                  Click="SaveButton_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
